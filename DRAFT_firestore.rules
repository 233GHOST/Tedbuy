rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for auth check and clean field comparisons
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && (
        request.auth.uid == userId ||
        userId == "user_" + request.auth.uid ||
        userId == "phone_" + request.auth.uid
      );
    }

    function isVerifiedUser() {
      return isSignedIn() && (
        request.auth.token.email_verified == true || 
        request.auth.token.firebase.sign_in_provider == 'phone'
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Basic validator to check for standard format ids
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Users Collection rules
    match /users/{userId} {
      function isValidUser(data) {
        return (isOwner(data.get('id', '')) || data.get('id', '').matches('^user_.*') || data.get('id', '').matches('^phone_.*')) &&
               data.username is string && data.username.size() <= 100 &&
               data.role in ['buyer', 'seller', 'both'] &&
               (data.get('email', null) == null || (data.get('email', '') is string && data.get('email', '').size() <= 150)) &&
               (data.get('phoneNumber', null) == null || (data.get('phoneNumber', '') is string && data.get('phoneNumber', '').size() <= 30)) &&
               (data.get('whatsAppNumber', null) == null || (data.get('whatsAppNumber', '') is string && data.get('whatsAppNumber', '').size() <= 30));
      }

      allow read: if true; // Public marketplace profiles are viewable by everyone
      allow create: if isSignedIn() && isValidId(userId) && isValidUser(incoming());
      // An unverified user can transition their profile on email verification, but other changes require full verification
      allow update: if isSignedIn() && isValidId(userId) && isOwner(userId) && isValidUser(incoming()) && (
        isVerifiedUser() ||
        incoming().diff(existing()).affectedKeys().hasOnly(['emailVerified'])
      );
      // Allow self-deletion during permanent account deletion!
      allow delete: if isSignedIn() && isOwner(userId);
    }

    // 2. Products Collection rules
    match /products/{productId} {
      function isValidProduct(data) {
        return data.get('id', '') is string && data.get('id', '').size() <= 128 &&
               data.get('sellerId', '') is string && data.get('sellerId', '').size() <= 128 &&
               data.get('title', '') is string && data.get('title', '').size() <= 1000 &&
               data.get('category', '') is string && data.get('category', '').size() <= 500;
      }

      allow read: if true; // Listings are public
      allow create: if isVerifiedUser() && isValidId(productId) && isValidProduct(incoming()) && isOwner(incoming().get('sellerId', ''));
      allow update: if isValidId(productId) && (
                      (isVerifiedUser() && isOwner(existing().get('sellerId', ''))) ||
                      incoming().diff(existing()).affectedKeys().hasOnly(['viewsCount'])
                    );
      allow delete: if isSignedIn() && isOwner(existing().get('sellerId', ''));
    }

    // 3. Chats Collection rules
    match /chats/{chatId} {
      function isValidChat(data) {
        return data.id is string && data.id.size() <= 128 &&
               data.productId is string && data.productId.size() <= 128 &&
               data.buyerId is string && data.buyerId.size() <= 128 &&
               data.sellerId is string && data.sellerId.size() <= 128 &&
               (data.get('tradeStatus', null) == null || data.get('tradeStatus', '') in ['pending', 'delivered', 'completed']);
      }

      allow read: if isSignedIn() && (isOwner(resource.data.buyerId) || isOwner(resource.data.sellerId));
      allow create: if isVerifiedUser() && isValidId(chatId) && isValidChat(incoming()) && isOwner(incoming().get('buyerId', ''));
      allow update: if isVerifiedUser() && isValidId(chatId) && 
                    (isOwner(existing().get('buyerId', '')) || isOwner(existing().get('sellerId', ''))) &&
                    isValidChat(incoming()) &&
                    incoming().get('id', '') == existing().get('id', '') &&
                    incoming().get('buyerId', '') == existing().get('buyerId', '') &&
                    incoming().get('sellerId', '') == existing().get('sellerId', '');
      allow delete: if isSignedIn() && (isOwner(resource.data.buyerId) || isOwner(resource.data.sellerId));
    }

    // 4. Messages Collection rules
    match /messages/{messageId} {
      function isValidMessage(data) {
        return data.id is string && data.id.size() <= 128 &&
               data.chatId is string && data.chatId.size() <= 128 &&
               isOwner(data.get('senderId', '')) &&
               data.recipientId is string && data.recipientId.size() <= 128 &&
               data.text is string && data.text.size() <= 5000;
      }

      allow read: if isSignedIn() && (isOwner(resource.data.senderId) || isOwner(resource.data.recipientId));
      allow create: if isVerifiedUser() && isValidId(messageId) && isValidMessage(incoming());
      allow update: if isSignedIn() &&
                       isOwner(existing().get('recipientId', '')) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['read']) &&
                       incoming().read == true;
      allow delete: if isSignedIn() && (isOwner(resource.data.senderId) || isOwner(resource.data.recipientId));
    }

    // 5. Reviews Collection rules
    match /reviews/{reviewId} {
      function isValidReview(data) {
        return data.id is string && data.id.size() <= 128 &&
               data.sellerId is string && data.sellerId.size() <= 128 &&
               data.buyerId is string && data.buyerId.size() <= 128 &&
               isOwner(data.get('buyerId', '')) &&
               (data.rating is int || data.rating is float) && data.rating >= 1 && data.rating <= 5 &&
               data.comment is string && data.comment.size() <= 2000;
      }

      allow read: if true; // Feedback ratings can be viewed on profiles
      allow create: if isVerifiedUser() && isValidId(reviewId) &&
                    incoming().get('buyerId', '') != incoming().get('sellerId', '') && // No self rates
                    isValidReview(incoming());
      allow update: if false; // Reviews are immutable
      allow delete: if isSignedIn() && (isOwner(resource.data.buyerId) || isOwner(resource.data.sellerId));
    }

    // 6. Notifications Collection rules
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId != null;
      allow update: if isSignedIn() && isOwner(resource.data.userId) &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && isOwner(resource.data.userId);
    }

    // 7. Deleted Emails Registry
    match /deletedEmails/{email} {
      allow read: if true; // Allow lookup during sign-up to see if email was deleted
      allow create: if isSignedIn(); // Allow writing record during account deletion
      allow update, delete: if false; // Permanent records
    }
  }
}
