rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for auth check and clean field comparisons
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // Checks if user is owner under different prefixes/integrations
    function isOwner(userId) {
      return isSignedIn() && (
        request.auth.uid == userId ||
        userId == "user_" + request.auth.uid ||
        "user_" + request.auth.uid == userId ||
        userId == "phone_" + request.auth.uid ||
        "phone_" + request.auth.uid == userId
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Basic validator to check for standard format ids
    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Users Collection rules
    match /users/{userId} {
      function isValidUser(data) {
        return isOwner(data.get('id', '')) &&
               data.username is string && data.username.size() <= 100 &&
               data.role in ['buyer', 'seller', 'both'] &&
               (data.get('email', null) == null || (data.get('email', '') is string && data.get('email', '').size() <= 150)) &&
               (data.get('phoneNumber', null) == null || (data.get('phoneNumber', '') is string && data.get('phoneNumber', '').size() <= 30)) &&
               (data.get('whatsAppNumber', null) == null || (data.get('whatsAppNumber', '') is string && data.get('whatsAppNumber', '').size() <= 30));
      }

      allow read: if true; // Public marketplace profiles are viewable by everyone
      allow create: if isSignedIn() && isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin()) && isValidId(userId) && isValidUser(incoming()) &&
                    incoming().get('id', '') == existing().get('id', '') &&
                    (incoming().get('isAdmin', false) == existing().get('isAdmin', false));
      allow delete: if isAdmin();
    }

    // 2. Products Collection rules
    match /products/{productId} {
      function isValidProduct(data) {
        return data.get('id', '') is string && data.get('id', '').size() <= 128 &&
               data.get('sellerId', '') is string && data.get('sellerId', '').size() <= 128 &&
               isOwner(data.get('sellerId', '')) && // Prevent cross-user document spoofing
               data.get('title', '') is string && data.get('title', '').size() <= 1000 &&
               data.get('category', '') is string && data.get('category', '').size() <= 500;
      }

      allow read: if true; // Listings are public
      allow create: if isSignedIn() && isValidId(productId) && isValidProduct(incoming());
      allow update: if isValidId(productId) && (
                      (isSignedIn() && isOwner(existing().get('sellerId', ''))) ||
                      (
                        // Allow view count and likes updates, but protect other fields
                        incoming().diff(existing()).affectedKeys().hasOnly(['viewsCount']) &&
                        incoming().get('viewsCount', 0) == existing().get('viewsCount', 0) + 1
                      ) ||
                      (
                        // Allow authenticated likes updates conforming to the user's authentic UID
                        isSignedIn() &&
                        incoming().diff(existing()).affectedKeys().hasAny(['likesCount', 'likedUserIds']) &&
                        incoming().diff(existing()).affectedKeys().hasOnly(['likesCount', 'likedUserIds']) &&
                        (
                          (incoming().get('likedUserIds', []).size() == existing().get('likedUserIds', []).size() + 1 &&
                           incoming().get('likedUserIds', []).hasAll([request.auth.uid]) &&
                           incoming().get('likesCount', 0) == existing().get('likesCount', 0) + 1)
                          ||
                          (incoming().get('likedUserIds', []).size() == existing().get('likedUserIds', []).size() - 1 &&
                           !incoming().get('likedUserIds', []).hasAll([request.auth.uid]) &&
                           incoming().get('likesCount', 0) == existing().get('likesCount', 0) - 1)
                        )
                      ) ||
                      isAdmin()
                    );
      allow delete: if isSignedIn() && (isOwner(existing().get('sellerId', '')) || isAdmin());
    }

    // 3. Chats Collection rules
    match /chats/{chatId} {
      function isValidChat(data) {
        return data.id is string && data.id.size() <= 128 &&
               data.productId is string && data.productId.size() <= 128 &&
               data.buyerId is string && data.buyerId.size() <= 128 &&
               data.sellerId is string && data.sellerId.size() <= 128 &&
               (data.get('tradeStatus', null) == null || data.get('tradeStatus', '') in ['pending', 'delivered', 'completed']);
      }

      allow read: if isSignedIn() && (resource.data.get('buyerId', '') == request.auth.uid || resource.data.get('sellerId', '') == request.auth.uid || isOwner(resource.data.get('buyerId', '')) || isOwner(resource.data.get('sellerId', '')) || isAdmin());
      allow create: if isSignedIn() && (isOwner(incoming().get('buyerId', '')) || isOwner(incoming().get('sellerId', ''))) && isValidId(chatId) && isValidChat(incoming());
      allow update: if isSignedIn() && (isOwner(existing().get('buyerId', '')) || isOwner(existing().get('sellerId', '')) || isAdmin()) && isValidId(chatId) && 
                    isValidChat(incoming()) &&
                    incoming().get('id', '') == existing().get('id', '') &&
                    incoming().get('buyerId', '') == existing().get('buyerId', '') &&
                    incoming().get('sellerId', '') == existing().get('sellerId', '');
      allow delete: if isAdmin();
    }

    // 4. Messages Collection rules
    match /messages/{messageId} {
      function isValidMessage(data) {
        return data.id is string && data.id.size() <= 128 &&
               data.chatId is string && data.chatId.size() <= 128 &&
               isOwner(data.get('senderId', '')) &&
               data.recipientId is string && data.recipientId.size() <= 128 &&
               data.text is string && data.text.size() <= 5000;
      }

      allow read: if isSignedIn() && (resource.data.get('senderId', '') == request.auth.uid || resource.data.get('recipientId', '') == request.auth.uid || isOwner(resource.data.get('senderId', '')) || isOwner(resource.data.get('recipientId', '')) || isAdmin());
      allow create: if isSignedIn() && isOwner(incoming().get('senderId', '')) && isValidId(messageId) && isValidMessage(incoming());
      allow update: if isSignedIn() && isOwner(existing().get('recipientId', '')) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['read']) &&
                       incoming().read == true;
      allow delete: if isAdmin();
    }

    // 5. Reviews Collection rules
    match /reviews/{reviewId} {
      function isValidReview(data) {
        return data.id is string && data.id.size() <= 128 &&
               data.sellerId is string && data.sellerId.size() <= 128 &&
               data.buyerId is string && data.buyerId.size() <= 128 &&
               isOwner(data.get('buyerId', '')) &&
               (data.rating is int || data.rating is float) && data.rating >= 1 && data.rating <= 5 &&
               data.comment is string && data.comment.size() <= 2000;
      }

      allow read: if true; // Feedback ratings can be viewed on profiles
      allow create: if isSignedIn() && isOwner(incoming().get('buyerId', '')) && isValidId(reviewId) &&
                    incoming().get('buyerId', '') != incoming().get('sellerId', '') && // No self rates
                    isValidReview(incoming());
      allow update: if false; // Reviews are immutable
      allow delete: if isAdmin(); // Only admins can moderate reviews
    }

    // 6. Notifications Collection rules
    match /notifications/{notifId} {
      function isValidNotification(data) {
        return data.id is string && data.id.size() <= 128 &&
               data.userId is string && data.userId.size() <= 128 &&
               data.title is string && data.title.size() <= 200 &&
               data.message is string && data.message.size() <= 2000;
      }

      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isOwner(resource.data.userId) || isAdmin());
      allow create: if isSignedIn() && isValidId(notifId) && isValidNotification(incoming());
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isOwner(resource.data.userId) || isAdmin()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['read']) &&
                    incoming().read is bool;
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isOwner(resource.data.userId) || isAdmin());
    }
  }
}
