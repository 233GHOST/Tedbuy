{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self' https: data: blob: 'unsafe-inline' 'unsafe-eval'; connect-src 'self' https: wss:; img-src 'self' https: data: blob: android-webview-video-poster:; style-src 'self' 'unsafe-inline' https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https:; frame-src 'self' https:;"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()"
        },
        {
          "key": "Link",
          "value": "</sitemap.xml>; rel=\"sitemap\", </.well-known/api-catalog>; rel=\"api-catalog\", </auth.md>; rel=\"service-doc\""
        }
      ]
    }
  ],
  "cleanUrls": true,
  "rewrites": [
    { "source": "/__/auth/:path*", "destination": "https://tedbuy-fb79a.firebaseapp.com/__/auth/:path*" },
    { "source": "/robots.txt", "destination": "/api/robots" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/sitemap-static.xml", "destination": "/api/sitemap-static" },
    { "source": "/sitemap-categories.xml", "destination": "/api/sitemap-categories" },
    { "source": "/sitemap-products-:page.xml", "destination": "/api/sitemap-products-:page" },
    { "source": "/sitemap-stores-:page.xml", "destination": "/api/sitemap-stores-:page" },
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/api", "destination": "/api" },
    { "source": "/auth.md", "destination": "/api" },
    { "source": "/.well-known/:path*", "destination": "/api" },
    {
      "source": "/:path*",
      "has": [{ "type": "header", "key": "accept", "value": "(.*text/markdown.*)" }],
      "destination": "/api"
    },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
