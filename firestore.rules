rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for auth check and clean field comparisons
    function isSignedIn() {
      return request.auth != null;
    }

    // Checks if user is owner under different prefixes (simplified and optimized)
    function isOwner(uid) {
      return isSignedIn() && (
        uid == request.auth.uid ||
        uid == "user_" + request.auth.uid ||
        uid == "phone_" + request.auth.uid ||
        (request.auth.token != null && "email" in request.auth.token && (uid == request.auth.token.email || uid.lower() == request.auth.token.email.lower()))
      );
    }

    // Helper to check if user has admin privileges based on verified email
    function isAdmin() {
      return isSignedIn() && 
             request.auth.token != null && 
             "email" in request.auth.token && 
             request.auth.token.email.lower() == 'asumaduvincent7@gmail.com';
    }

    // Helper to check robust ownership of a product (via direct UID or via email verification of Firestore user document)
    function isProductOwner(sellerId) {
      return isOwner(sellerId) || (
        isSignedIn() && 
        sellerId is string && 
        sellerId.size() > 0 &&
        request.auth.token != null && 
        "email" in request.auth.token && 
        exists(/databases/$(database)/documents/users/$(sellerId)) && 
        request.auth.token.email.lower() == get(/databases/$(database)/documents/users/$(sellerId)).data.get('email', '').lower()
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Basic validator to check for standard format ids
    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Users Collection rules
    match /users/{userId} {
      function isValidUser(data) {
        return data.get('username', '') is string && data.get('username', '').size() <= 100 &&
               data.get('role', 'both') in ['buyer', 'seller', 'both'] &&
               (data.get('email', null) == null || (data.get('email', '') is string && data.get('email', '').size() <= 150)) &&
               (data.get('phoneNumber', null) == null || (data.get('phoneNumber', '') is string && data.get('phoneNumber', '').size() <= 30));
      }

      allow read: if true; // Public marketplace profiles are viewable by everyone
      allow create: if (isOwner(userId) || (isSignedIn() && (userId.matches('^user_.*') || userId.matches('^phone_.*')))) && isValidId(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin() || (request.auth.token != null && "email" in request.auth.token && request.auth.token.email.lower() == existing().get('email', '').lower())) &&
                    isValidId(userId) &&
                    isValidUser(incoming()) &&
                    incoming().get('id', userId) == existing().get('id', userId);
      allow delete: if isSignedIn() && (
        isOwner(userId) || 
        isAdmin() ||
        (request.auth.token != null && "email" in request.auth.token && request.auth.token.email.lower() == resource.data.get('email', '').lower())
      );
    }

    // 2. Products Collection rules
    match /products/{productId} {
      function isValidProduct(data) {
        return data.get('id', productId) is string && data.get('id', productId).size() <= 128 &&
               data.get('sellerId', '') is string && data.get('sellerId', '').size() <= 128 &&
               data.get('title', '') is string && data.get('title', '').size() <= 1000 &&
               data.get('category', '') is string && data.get('category', '').size() <= 100;
      }

      allow read: if true; // Listings are public
      allow create: if isSignedIn() && isValidId(productId) && isValidProduct(incoming());
      allow update: if isValidId(productId) && isValidProduct(incoming()) && (
                      isAdmin() ||
                      isProductOwner(existing().get('sellerId', '')) ||
                      incoming().diff(existing()).affectedKeys().hasOnly(['viewsCount', 'isSold', 'likesCount', 'likedUserIds'])
                    );
      allow delete: if isAdmin() || isProductOwner(existing().get('sellerId', ''));
    }

    // 3. Chats Collection rules
    match /chats/{chatId} {
      function isValidChat(data) {
        return data.get('id', chatId) is string && data.get('id', chatId).size() <= 128 &&
               data.get('productId', '') is string && data.get('productId', '').size() <= 128 &&
               data.get('buyerId', '') is string && data.get('buyerId', '').size() <= 128 &&
               data.get('sellerId', '') is string && data.get('sellerId', '').size() <= 128 &&
               (data.get('tradeStatus', null) == null || data.get('tradeStatus', '') in ['pending', 'delivered', 'completed']);
      }

      allow read: if !isSignedIn() || 
                     resource.data.buyerId == request.auth.uid ||
                     resource.data.sellerId == request.auth.uid ||
                     (request.auth.token != null && "email" in request.auth.token && (resource.data.buyerId == request.auth.token.email || resource.data.sellerId == request.auth.token.email)) ||
                     isAdmin();
      allow create: if (isOwner(incoming().get('buyerId', '')) || incoming().get('buyerId', '').matches('^user_.*') || isAdmin()) && isValidId(chatId) && isValidChat(incoming());
      allow update: if (isOwner(existing().get('buyerId', '')) || isOwner(existing().get('sellerId', '')) || isAdmin()) && isValidId(chatId) && 
                    isValidChat(incoming()) &&
                    incoming().get('id', chatId) == existing().get('id', chatId) &&
                    incoming().get('buyerId', '') == existing().get('buyerId', '') &&
                    incoming().get('sellerId', '') == existing().get('sellerId', '');
      allow delete: if isAdmin();
    }

    // 4. Messages Collection rules
    match /messages/{messageId} {
      function isValidMessage(data) {
        return data.get('id', messageId) is string && data.get('id', messageId).size() <= 128 &&
               data.get('chatId', '') is string && data.get('chatId', '').size() <= 128 &&
               (isOwner(data.get('senderId', '')) || data.get('senderId', '').matches('^user_.*') || isAdmin()) &&
               data.get('recipientId', '') is string && data.get('recipientId', '').size() <= 128 &&
               data.get('text', '') is string && data.get('text', '').size() <= 5000;
      }

      allow read: if !isSignedIn() || 
                     resource.data.senderId == request.auth.uid ||
                     resource.data.recipientId == request.auth.uid ||
                     (request.auth.token != null && "email" in request.auth.token && (resource.data.senderId == request.auth.token.email || resource.data.recipientId == request.auth.token.email)) ||
                     isAdmin();
      allow create: if (isOwner(incoming().get('senderId', '')) || incoming().get('senderId', '').matches('^user_.*') || isAdmin()) && isValidId(messageId) && isValidMessage(incoming());
      allow update: if (isOwner(existing().get('recipientId', '')) || isAdmin()) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['read']) &&
                       incoming().read == true;
      allow delete: if isAdmin();
    }

    // 5. Reviews Collection rules
    match /reviews/{reviewId} {
      function isValidReview(data) {
        return data.get('id', reviewId) is string && data.get('id', reviewId).size() <= 128 &&
               data.get('sellerId', '') is string && data.get('sellerId', '').size() <= 128 &&
               data.get('buyerId', '') is string && data.get('buyerId', '').size() <= 128 &&
               (isOwner(data.get('buyerId', '')) || data.get('buyerId', '').matches('^user_.*') || data.get('id', '').matches('^rev_.*') || isAdmin()) &&
               (data.get('rating', 0) is int || data.get('rating', 0) is float) && data.get('rating', 0) >= 1 && data.get('rating', 0) <= 5 &&
               data.get('comment', '') is string && data.get('comment', '').size() <= 2000;
      }

      allow read: if true; // Feedback ratings can be viewed on profiles
      allow create: if (isOwner(incoming().get('buyerId', '')) || incoming().get('buyerId', '').matches('^user_.*') || isAdmin()) && isValidId(reviewId) &&
                     incoming().get('buyerId', '') != incoming().get('sellerId', '') && // No self rates
                     isValidReview(incoming());
      allow update, delete: if isAdmin(); // Reviews can be deleted/updated only by admin if needed
    }

    // 6. DeletedEmails Collection rules
    match /deletedEmails/{email} {
      allow read, write: if isSignedIn();
    }

    // 7. Notifications Collection rules
    match /notifications/{notificationId} {
      allow read: if resource.data.userId == request.auth.uid || 
                     (request.auth.token != null && "email" in request.auth.token && resource.data.userId == request.auth.token.email) ||
                     isAdmin();
      allow create, update, delete: if isSignedIn();
    }

    // 8. StoreNames Collection rules
    match /storeNames/{storeName} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
