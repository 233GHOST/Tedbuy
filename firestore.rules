rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && (
        request.auth.uid == userId ||
        userId == "user_" + request.auth.uid ||
        userId == "phone_" + request.auth.uid
      );
    }

    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && (
        userId == request.auth.uid || 
        userId == "user_" + request.auth.uid ||
        userId == "phone_" + request.auth.uid
      ) && (
        // Standard users cannot make themselves admin, except the verified platform owner
        (!("isAdmin" in request.resource.data) || request.resource.data.isAdmin != true || (request.auth.token.email.lower() == "asumaduvincent7@gmail.com" && request.auth.token.email_verified == true))
      );
      allow update: if isSignedIn() && (
        userId == request.auth.uid || 
        userId == "user_" + request.auth.uid ||
        userId == "phone_" + request.auth.uid
      ) && (
        // Users cannot make themselves admin or change their admin status
        (!("isAdmin" in request.resource.data) || request.resource.data.isAdmin == resource.data.isAdmin)
      ) && (
        // Protect the admin profile from being maliciously modified or hijacked by non-admin emails
        (resource.data.email != "asumaduvincent7@gmail.com") ||
        (request.auth.token.email.lower() == "asumaduvincent7@gmail.com" && request.auth.token.email_verified == true)
      );
      allow delete: if false;
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
                      isOwner(resource.data.sellerId) ||
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewsCount', 'isSold', 'likesCount', 'likedUserIds'])
                    );
      allow delete: if isSignedIn() && isOwner(resource.data.sellerId);
    }

    match /chats/{chatId} {
      allow read: if isSignedIn() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid);
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    match /messages/{messageId} {
      allow read: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.recipientId == request.auth.uid);
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /deletedEmails/{email} {
      allow read, write: if isSignedIn();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.userId == "user_" + request.auth.uid || resource.data.userId == "phone_" + request.auth.uid);
      allow create, update, delete: if isSignedIn();
    }

    match /storeNames/{storeName} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
