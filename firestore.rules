rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for auth check and clean field comparisons
    function isSignedIn() {
      return request.auth != null;
    }

    // Checks if user is owner under different prefixes (strictly bound to request.auth.uid)
    function isOwner(uid) {
      return isSignedIn() && (
        uid == request.auth.uid ||
        uid == "user_" + request.auth.uid ||
        uid == "phone_" + request.auth.uid
      );
    }

    // Helper to check if user has admin privileges. Recognizes, in order:
    // 1) A Firebase Auth custom claim (admin: true) - not currently set by the app, kept for future use.
    // 2) The verified super-admin email (hardcoded fallback).
    // 3) The users/{uid}.isAdmin Firestore field - this is the mechanism the app actually
    //    uses everywhere (frontend currentUser.isAdmin, and server verifyAdmin()), so the
    //    rules must recognize it too or admin-only writes made over the REST API (e.g. on
    //    Vercel, where the Admin SDK is disabled) will be silently rejected for any admin
    //    other than the hardcoded email above.
    function isAdmin() {
      return isSignedIn() && (
        // Check Firebase Auth custom claim (set via Admin SDK)
        (request.auth.token != null && "admin" in request.auth.token && request.auth.token.admin == true) ||
        // Check users collection isAdmin field (must be email-verified)
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true &&
         "email_verified" in request.auth.token &&
         request.auth.token.email_verified == true)
      );
    }

    function isEmailVerifiedOwner(email) {
      return isSignedIn() &&
             request.auth.token != null &&
             "email" in request.auth.token &&
             "email_verified" in request.auth.token &&
             request.auth.token.email_verified == true &&
             request.auth.token.email.lower() == email.lower();
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Basic validator to check for standard format ids
    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Users Collection rules
    match /users/{userId} {
      function isValidUser(data) {
        return data.get('username', '') is string && data.get('username', '').size() <= 100 &&
               data.get('role', 'both') in ['buyer', 'seller', 'both'] &&
               (data.get('email', null) == null || (data.get('email', '') is string && data.get('email', '').size() <= 150)) &&
               (data.get('phoneNumber', null) == null || (data.get('phoneNumber', '') is string && data.get('phoneNumber', '').size() <= 30));
      }

      allow read: if true; // Public marketplace profiles are viewable by everyone
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) && (incoming().get('isAdmin', false) == false || isAdmin());
      allow update: if (isOwner(userId) || isAdmin()) &&
                    isValidId(userId) &&
                    isValidUser(incoming()) &&
                    incoming().get('id', userId) == existing().get('id', userId) &&
                    (incoming().get('isAdmin', false) == existing().get('isAdmin', false) || isAdmin());
      allow delete: if isSignedIn() && (isOwner(userId) || isAdmin() || isEmailVerifiedOwner(existing().get('email', '')));
    }

    // 2. Products Collection rules
    match /products/{productId} {
      function isValidProduct(data) {
        return data.get('id', productId) is string && data.get('id', productId).size() <= 128 &&
               data.get('sellerId', '') is string && data.get('sellerId', '').size() <= 128 &&
               data.get('title', '') is string && data.get('title', '').size() <= 1000 &&
               data.get('category', '') is string && data.get('category', '').size() <= 100;
      }

      allow read: if true; // Listings are public
      allow create: if isSignedIn() && isOwner(incoming().get('sellerId', '')) && isValidId(productId) && isValidProduct(incoming());
      allow update: if isValidId(productId) && (
                      isValidProduct(incoming()) && (
                        isAdmin() ||
                        // Let product owners update details like title, description, category, etc.,
                        // but strictly prevent them from manipulating boost or ranking fields.
                        (
                          isOwner(existing().get('sellerId', '')) &&
                          !incoming().diff(existing()).affectedKeys().hasAny([
                            'boostStatus', 'boostPlan', 'boostStartDate', 'boostEndDate', 
                            'boostPriority', 'priorityScore', 'lastBoostedAt', 'boostHistory',
                            'boostAmount', 'boostPackagePrice', 'boostPriorityLevel', 
                            'remainingBoostTime', 'lastBoostPurchase'
                          ])
                        ) ||
                        // Allow updating sellerId if migrating account (changing from old UID to new UID of same verified email)
                        (
                          exists(/databases/$(database)/documents/users/$(existing().get('sellerId', ''))) &&
                          isEmailVerifiedOwner(get(/databases/$(database)/documents/users/$(existing().get('sellerId', ''))).data.get('email', '')) &&
                          isOwner(incoming().get('sellerId', ''))
                        ) ||
                        // Allow clearing/expiring boosts (e.g. background job setting boostStatus to false)
                        (
                          existing().get('boostStatus', false) == true &&
                          incoming().get('boostStatus', false) == false &&
                          incoming().diff(existing()).affectedKeys().hasOnly([
                            'boostStatus', 'boostPriority', 'priorityScore', 
                            'boostPriorityLevel', 'remainingBoostTime'
                          ])
                        ) ||
                        // Let social-only increments run with strict integrity checks
                        (incoming().diff(existing()).affectedKeys().hasOnly(['viewsCount', 'likesCount', 'likedUserIds']) &&
                         (incoming().get('viewsCount', 0) == existing().get('viewsCount', 0) + 1 || incoming().get('viewsCount', 0) == existing().get('viewsCount', 0)) &&
                         (!incoming().diff(existing()).affectedKeys().hasAny(['likesCount', 'likedUserIds']) || (
                            isSignedIn() &&
                            incoming().get('likesCount', 0) == incoming().get('likedUserIds', []).size() &&
                            (
                              (incoming().get('likedUserIds', []).size() == existing().get('likedUserIds', []).size() + 1 &&
                               incoming().get('likedUserIds', []).toSet().difference(existing().get('likedUserIds', []).toSet()).hasOnly([request.auth.uid])) ||
                              (incoming().get('likedUserIds', []).size() == existing().get('likedUserIds', []).size() - 1 &&
                               existing().get('likedUserIds', []).toSet().difference(incoming().get('likedUserIds', []).toSet()).hasOnly([request.auth.uid]))
                            )
                         ))
                        )
                      ))
                    );
      allow delete: if isAdmin() || isOwner(existing().get('sellerId', ''));
    }

    // 3. Chats Collection rules
    match /chats/{chatId} {
      function isValidChat(data) {
        return data.get('id', chatId) is string && data.get('id', chatId).size() <= 128 &&
               data.get('productId', '') is string && data.get('productId', '').size() <= 128 &&
               data.get('buyerId', '') is string && data.get('buyerId', '').size() <= 128 &&
               data.get('sellerId', '') is string && data.get('sellerId', '').size() <= 128 &&
               (data.get('tradeStatus', null) == null || data.get('tradeStatus', '') in ['pending', 'delivered', 'completed']);
      }

      allow read: if isSignedIn() && (isOwner(resource.data.get('buyerId', '')) || isOwner(resource.data.get('sellerId', '')) || isAdmin());
      allow create: if isSignedIn() && (isOwner(incoming().get('buyerId', '')) || isAdmin()) && isValidId(chatId) && isValidChat(incoming());
      allow update: if isSignedIn() && isValidId(chatId) && isValidChat(incoming()) && (
                      isAdmin() || (
                        // Terminal State Lock: Once completed, no further updates by normal users are allowed
                        existing().get('tradeStatus', 'pending') != 'completed' &&
                        incoming().get('id', chatId) == existing().get('id', chatId) &&
                        incoming().get('buyerId', '') == existing().get('buyerId', '') &&
                        incoming().get('sellerId', '') == existing().get('sellerId', '') &&
                        (
                          // Action 1: New message text sent (any chat participant)
                          ( (isOwner(existing().get('buyerId', '')) || isOwner(existing().get('sellerId', ''))) &&
                            incoming().diff(existing()).affectedKeys().hasOnly(['lastMessageText', 'lastMessageTime'])
                          ) ||
                          // Action 2: Seller marks as delivered
                          ( isOwner(existing().get('sellerId', '')) &&
                            incoming().diff(existing()).affectedKeys().hasOnly(['deliveredBySeller', 'tradeStatus', 'lastMessageText', 'lastMessageTime']) &&
                            incoming().get('deliveredBySeller', false) == true &&
                            incoming().get('tradeStatus', '') == 'delivered' &&
                            incoming().get('pickedUpByBuyer', false) == existing().get('pickedUpByBuyer', false)
                          ) ||
                          // Action 3: Buyer marks as completed/picked up
                          ( isOwner(existing().get('buyerId', '')) &&
                            incoming().diff(existing()).affectedKeys().hasOnly(['pickedUpByBuyer', 'tradeStatus', 'lastMessageText', 'lastMessageTime']) &&
                            incoming().get('pickedUpByBuyer', false) == true &&
                            incoming().get('tradeStatus', '') == 'completed' &&
                            existing().get('deliveredBySeller', false) == true &&
                            incoming().get('deliveredBySeller', false) == true
                          )
                        )
                      )
                    );
      allow delete: if isAdmin();
    }

    // 4. Messages Collection rules
    match /messages/{messageId} {
      function isValidMessage(data) {
        let chat = get(/databases/$(database)/documents/chats/$(data.get('chatId', ''))).data;
        return data.get('id', messageId) is string && data.get('id', messageId).size() <= 128 &&
               data.get('chatId', '') is string && data.get('chatId', '').size() <= 128 &&
               (isOwner(data.get('senderId', '')) || (isAdmin() && data.get('senderId', '') == 'user_ted_ceo_support')) &&
               data.get('recipientId', '') is string && data.get('recipientId', '').size() <= 128 &&
               data.get('text', '') is string && data.get('text', '').size() <= 5000 &&
               (
                 (data.get('senderId', '') == chat.get('buyerId', '') && data.get('recipientId', '') == chat.get('sellerId', '')) ||
                 (data.get('senderId', '') == chat.get('sellerId', '') && data.get('recipientId', '') == chat.get('buyerId', ''))
               );
      }

      allow read: if isSignedIn() && (isOwner(resource.data.get('senderId', '')) || isOwner(resource.data.get('recipientId', '')) || isAdmin());
      allow create: if isSignedIn() && (isOwner(incoming().get('senderId', '')) || (isAdmin() && incoming().get('senderId', '') == 'user_ted_ceo_support')) && isValidId(messageId) && isValidMessage(incoming());
      allow update: if isSignedIn() && (isOwner(existing().get('recipientId', '')) || isAdmin()) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['read']) &&
                       incoming().read == true;
      allow delete: if isAdmin();
    }

    // 5. Reviews Collection rules
    match /reviews/{reviewId} {
      function isValidReview(data) {
        return data.get('id', reviewId) is string && data.get('id', reviewId).size() <= 128 &&
               data.get('sellerId', '') is string && data.get('sellerId', '').size() <= 128 &&
               data.get('buyerId', '') is string && data.get('buyerId', '').size() <= 128 &&
               isOwner(data.get('buyerId', '')) &&
               (data.get('rating', 0) is int || data.get('rating', 0) is float) && data.get('rating', 0) >= 1 && data.get('rating', 0) <= 5 &&
               data.get('comment', '') is string && data.get('comment', '').size() <= 2000;
      }

      allow read: if true; // Feedback ratings can be viewed on profiles
      allow create: if isSignedIn() && 
                     isOwner(incoming().get('buyerId', '')) && 
                     isValidId(reviewId) &&
                     incoming().get('buyerId', '') != incoming().get('sellerId', '') && // No self rates
                     isValidReview(incoming());
      allow update, delete: if isAdmin(); // Reviews can be deleted/updated only by admin if needed
    }

    // 6. DeletedEmails Collection rules (strictly tied to own email address or admin)
    match /deletedEmails/{email} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && (request.auth.token != null && "email" in request.auth.token && request.auth.token.email.lower() == email.lower()));
    }

    // 7. Notifications Collection rules (strictly bound to active recipient owner)
    match /notifications/{notificationId} {
      function isValidNotification(data) {
        return data.get('id', notificationId) is string && data.get('id', notificationId).size() <= 128 &&
               data.get('userId', '') is string && data.get('userId', '').size() <= 128 &&
               data.get('type', '') in ['post_created', 'new_follower'] &&
               data.get('title', '') is string && data.get('title', '').size() <= 500 &&
               data.get('message', '') is string && data.get('message', '').size() <= 1000 &&
               (data.get('triggerUserId', '') == request.auth.uid || (isAdmin() && data.get('triggerUserId', '') == 'user_ted_ceo_support'));
      }

      allow read: if isSignedIn() && (isOwner(resource.data.get('userId', '')) || isAdmin());
      allow create: if isSignedIn() && isValidId(notificationId) && isValidNotification(incoming());
      allow update, delete: if isSignedIn() && (isOwner(resource.data.get('userId', '')) || isAdmin());
    }

    // 8. StoreNames Collection rules (strictly bound to owner claims)
    match /storeNames/{storeName} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().get('userId', '') == request.auth.uid;
      allow update: if isSignedIn() && existing().get('userId', '') == request.auth.uid && incoming().get('userId', '') == request.auth.uid;
      allow delete: if isAdmin() || (isSignedIn() && (
        existing().get('userId', '') == request.auth.uid ||
        (
          exists(/databases/$(database)/documents/users/$(existing().get('userId', ''))) &&
          isEmailVerifiedOwner(get(/databases/$(database)/documents/users/$(existing().get('userId', ''))).data.get('email', ''))
        )
      ));
    }

    // 9. Boost Purchases Collection rules
    match /boost_purchases/{purchaseId} {
      allow read: if isSignedIn() && (isOwner(resource.data.get('userId', '')) || isAdmin());
      allow create: if isSignedIn() && (isOwner(incoming().get('userId', '')) || isAdmin()) && isValidId(purchaseId);
      allow update, delete: if isAdmin();
    }

    // 10. Reports Collection rules
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && 
                    isOwner(incoming().get('reporterId', '')) && 
                    isValidId(reportId) &&
                    incoming().get('id', '') == reportId &&
                    incoming().get('productId', '') is string &&
                    incoming().get('reason', '') is string;
      allow update, delete: if isAdmin();
    }
  }
}
