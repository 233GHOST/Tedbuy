rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "asumaduvincent7@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == "asumaduvincent7@gmail.com"
        ))
      );
    }

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Users collection
    match /users/{userId} {
      allow read: if true;
      allow create, update: if isSignedIn() && (request.auth.uid == userId || userId == "user_" + request.auth.uid || userId == "phone_" + request.auth.uid);
      allow delete: if isSignedIn() && (request.auth.uid == userId || userId == "user_" + request.auth.uid || userId == "phone_" + request.auth.uid);
    }

    // 2. Products collection
    match /products/{productId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.sellerId != null;
      allow update: if isSignedIn() && (
        isAdmin() ||
        isOwner(resource.data.sellerId) || 
        resource.data.sellerId == "user_" + request.auth.uid ||
        resource.data.sellerId == "phone_" + request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewsCount'])
      );
      allow delete: if isSignedIn() && (
        isAdmin() ||
        isOwner(resource.data.sellerId) ||
        resource.data.sellerId == "user_" + request.auth.uid ||
        resource.data.sellerId == "phone_" + request.auth.uid
      );
    }

    // 3. Chats collection
    match /chats/{chatId} {
      allow read: if isSignedIn() && (
        resource.data.buyerId == request.auth.uid || 
        resource.data.sellerId == request.auth.uid ||
        resource.data.buyerId == "user_" + request.auth.uid ||
        resource.data.sellerId == "user_" + request.auth.uid
      );
      allow create: if isSignedIn() && request.resource.data.buyerId != null;
      allow update: if isSignedIn() && (
        resource.data.buyerId == request.auth.uid || 
        resource.data.sellerId == request.auth.uid ||
        resource.data.buyerId == "user_" + request.auth.uid ||
        resource.data.sellerId == "user_" + request.auth.uid
      );
      allow delete: if isSignedIn() && (
        resource.data.buyerId == request.auth.uid || 
        resource.data.sellerId == request.auth.uid ||
        resource.data.buyerId == "user_" + request.auth.uid ||
        resource.data.sellerId == "user_" + request.auth.uid
      );
    }

    // 4. Messages collection
    match /messages/{messageId} {
      allow read: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.recipientId == request.auth.uid ||
        resource.data.senderId == "user_" + request.auth.uid ||
        resource.data.recipientId == "user_" + request.auth.uid
      );
      allow create: if isSignedIn() && request.resource.data.senderId != null;
      allow update: if isSignedIn() && (
        (resource.data.recipientId == request.auth.uid || resource.data.recipientId == "user_") && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
      );
      allow delete: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.recipientId == request.auth.uid ||
        resource.data.senderId == "user_" + request.auth.uid ||
        resource.data.recipientId == "user_" + request.auth.uid
      );
    }

    // 5. Reviews collection
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.buyerId != null;
      allow update, delete: if isSignedIn() && (
        resource.data.buyerId == request.auth.uid || 
        resource.data.sellerId == request.auth.uid ||
        resource.data.buyerId == "user_" + request.auth.uid ||
        resource.data.sellerId == "user_" + request.auth.uid
      );
    }

    // 6. Notifications collection
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.userId == "user_" + request.auth.uid
      );
      allow create: if isSignedIn() && request.resource.data.userId != null;
      allow update: if isSignedIn() && (
        (resource.data.userId == request.auth.uid || resource.data.userId == "user_" + request.auth.uid) && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
      );
      allow delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.userId == "user_" + request.auth.uid
      );
    }

    // 7. Deleted Emails collection
    match /deletedEmails/{email} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
  }
}
