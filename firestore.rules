rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isValidString(val, max) {
      return val is string && val.size() <= max;
    }

    // =========================
    // USERS
    // =========================
    match /users/{userId} {

      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.id == request.auth.uid;

      allow update: if signedIn()
        && request.resource.data.id == request.auth.uid;

      allow delete: if false;
    }

    // =========================
    // PRODUCTS (PUBLIC READ)
    // =========================
    match /products/{productId} {

      allow read: if true;

      allow create: if signedIn()
        && request.resource.data.sellerId == request.auth.uid;

      allow update: if signedIn()
        && resource.data.sellerId == request.auth.uid;

      allow delete: if signedIn()
        && resource.data.sellerId == request.auth.uid;
    }

    // =========================
    // CHATS (ONLY USERS IN CHAT)
    // =========================
    match /chats/{chatId} {

      allow read: if signedIn()
        && (resource.data.buyerId == request.auth.uid
        || resource.data.sellerId == request.auth.uid);

      allow create: if signedIn();

      allow update: if signedIn()
        && (resource.data.buyerId == request.auth.uid
        || resource.data.sellerId == request.auth.uid);
    }

    // =========================
    // MESSAGES (CHAT PARTICIPANTS ONLY)
    // =========================
    match /messages/{messageId} {

      allow read: if signedIn()
        && (resource.data.senderId == request.auth.uid
        || resource.data.recipientId == request.auth.uid);

      allow create: if signedIn()
        && request.resource.data.senderId == request.auth.uid;

      allow update, delete: if false;
    }

    // =========================
    // REVIEWS (PUBLIC READ, AUTH WRITE)
    // =========================
    match /reviews/{reviewId} {

      allow read: if true;

      allow create: if signedIn()
        && request.resource.data.buyerId == request.auth.uid
        && request.resource.data.buyerId != request.resource.data.sellerId;

      allow update, delete: if false;
    }

  }
}
