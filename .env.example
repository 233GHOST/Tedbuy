# Paystack Gateway API Keys
# Server-side Secret Key (keep secure, never prefix with VITE_)
PAYSTACK_SECRET_KEY=

# Client-side Public Key (exposed to browser for loading payment popup)
VITE_PAYSTACK_PUBLIC_KEY=

# Scheduled Cron Trigger Security Secret
CRON_SECRET=

# Supabase (Option 4) Credentials
# Set these to activate the free, durable Supabase cloud database integration
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_DISABLE_SUPABASE=

# Firebase Client-side Configuration (used for Render/Vercel deployment)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_FIRESTORE_DATABASE_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Brevo (Sendinblue) Transactional Email API Keys
# Server-side Secret API Key (never prefix with VITE_)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=

# Optional Custom Super-Administrator Security PIN (6 digits, defaults to hash of "559102")
VITE_ADMIN_PIN=

