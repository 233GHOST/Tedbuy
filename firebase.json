{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "run": {
          "serviceId": "REPLACE_WITH_YOUR_CLOUD_RUN_SERVICE_NAME",
          "region": "europe-west2"
        }
      },
      {
        "source": "/.well-known/**",
        "run": {
          "serviceId": "REPLACE_WITH_YOUR_CLOUD_RUN_SERVICE_NAME",
          "region": "europe-west2"
        }
      },
      {
        "source": "/auth.md",
        "run": {
          "serviceId": "REPLACE_WITH_YOUR_CLOUD_RUN_SERVICE_NAME",
          "region": "europe-west2"
        }
      },
      {
        "source": "/sitemap**.xml",
        "run": {
          "serviceId": "REPLACE_WITH_YOUR_CLOUD_RUN_SERVICE_NAME",
          "region": "europe-west2"
        }
      },
      {
        "source": "/robots.txt",
        "run": {
          "serviceId": "REPLACE_WITH_YOUR_CLOUD_RUN_SERVICE_NAME",
          "region": "europe-west2"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
